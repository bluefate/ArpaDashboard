# ArpaDashboard environment
PORT=8787
HOST=0.0.0.0

# Required: protect write endpoints (Bearer token)
# Generate with: openssl rand -base64 32
API_KEY=change-me-to-a-long-random-secret

# Zones allowed by the API (comma-separated)
ALLOWED_ZONES=home.arpa,dev.home.arpa

# Where DNS A records should point when proxy=true (your Caddy LAN IP)
CADDY_IP=192.168.1.10

# Optional: Pi-hole v6 API (leave empty to skip live DNS writes)
PIHOLE_URL=http://192.168.1.2
PIHOLE_PASSWORD=

# Optional: auto Caddy routes for proxied services
# Write a snippet Caddy imports, then optionally reload via the admin API.
# CADDY_SNIPPET_PATH=/data/caddy/arpa-dashboard.caddy
# CADDY_SNIPPET_ZONES=dev.home.arpa
# CADDY_ADMIN_URL=http://192.168.1.10:2019
# CADDY_CADDYFILE_PATH=/etc/caddy/Caddyfile
CADDY_SNIPPET_PATH=
CADDY_SNIPPET_ZONES=
CADDY_ADMIN_URL=
CADDY_CADDYFILE_PATH=

# Dashboard data file
DATA_PATH=./data/services.json
