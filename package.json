{
  "name": "arpa-dashboard",
  "version": "0.1.0",
  "description": "Home-lab service dashboard with protected API for Pi-hole DNS and Caddy reverse-proxy registration under home.arpa",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "John Hernandez / BluefateLabs",
  "homepage": "https://bluefatelabs.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/bluefate/ArpaDashboard.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@hono/swagger-ui": "^0.6.1",
    "hono": "^4.8.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
